From 8fbdbd54481940ea30ee021f8250a833d2dedcfa Mon Sep 17 00:00:00 2001
From: Chris Burr <christopher.burr@cern.ch>
Date: Tue, 3 Mar 2026 21:02:38 +0100
Subject: [PATCH] fix: Set Cython module name for multi-phase init
 compatibility

Cython 3.x with Python 3.12+ uses PEP 489 multi-phase initialization
by default, which requires the module name in PyModuleDef to match the
fully qualified import name. Without --module-name, Cython sets the
name to 'core' (from the filename) but Python expects 'rivet.core',
causing "initialization of core did not return an extension module".

Pass --module-name rivet.core to Cython so the generated PyModuleDef
has the correct fully qualified name.
---
 pyext/rivet/Makefile.am | 1 +
 1 file changed, 1 insertion(+)

diff --git a/pyext/rivet/Makefile.am b/pyext/rivet/Makefile.am
index 3bab16f69..bff4045db 100644
--- a/pyext/rivet/Makefile.am
+++ b/pyext/rivet/Makefile.am
@@ -17,6 +17,7 @@ if WITH_CYTHON
 RIVETINCLUDE = $(top_srcdir)/include/Rivet/
 core.cpp: core.pyx rivet.pxd $(RIVETINCLUDE)/Analysis.hh $(RIVETINCLUDE)/AnalysisHandler.hh $(RIVETINCLUDE)/AnalysisLoader.hh $(RIVETINCLUDE)/Run.hh $(RIVETINCLUDE)/Tools/ProjectionTreePlotter.hh
 	$(CYTHON) $(srcdir)/core.pyx --cplus -2 \
+	   --module-name rivet.core \
 	   -I $(srcdir) -I $(srcdir)/include \
 	   -I $(builddir) -I $(builddir)/include \
 	   -o $@
