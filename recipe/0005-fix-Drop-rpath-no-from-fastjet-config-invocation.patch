From f5ed374e3437891d1a8f4090bb90621af3a0f516 Mon Sep 17 00:00:00 2001
From: Chris Burr <christopher.burr@cern.ch>
Date: Tue, 3 Mar 2026 13:18:58 +0100
Subject: [PATCH] fix: Drop --rpath=no from fastjet-config invocation

The conda-forge fastjet-config has a bug where the shared lib
detection variable is empty, causing --rpath=no to emit an error
message to stdout that contaminates the linker flags. Since conda
handles rpaths independently, this flag is unnecessary.
---
 configure.ac | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/configure.ac b/configure.ac
index a2a4449d7..e5f6a3e1d 100644
--- a/configure.ac
+++ b/configure.ac
@@ -167,7 +167,7 @@ if test -f "$FJCONFIG"; then
   if test "$fjmajor" -lt 3 -o "$fjminor" -lt 2 ; then  #< only works for v3.x
     AC_MSG_ERROR([FastJet version 3.2.0 or later is required])
   fi
-  FASTJETLIBADD="$($FJCONFIG --libs --plugins --rpath=no)"
+  FASTJETLIBADD="$($FJCONFIG --libs --plugins)"
 else
   FASTJETLIBADD="-L$FASTJETLIBPATH -l$FASTJETLIBNAME -lfastjetplugins"
 fi
-- 
