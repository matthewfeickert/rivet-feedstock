From 48769a1bf3a2b634c776aebbd13e7015788cadfc Mon Sep 17 00:00:00 2001
From: Chris Burr <christopher.burr@cern.ch>
Date: Tue, 3 Mar 2026 16:59:05 +0100
Subject: [PATCH] fix: Add rpath to build tree for local core.so on macOS

When building with RIVET_LOCAL=1 (for make check), add an rpath
pointing to the build tree's .libs directory so the dynamic loader
can find libRivet.dylib without relying on DYLD_LIBRARY_PATH (which
is stripped by SIP) or install_name_tool (which breaks code signing
with cctools-port).
---
 pyext/build.py.in | 7 ++++++-
 1 file changed, 6 insertions(+), 1 deletion(-)

diff --git a/pyext/build.py.in b/pyext/build.py.in
index a15b706a6..81342565a 100644
--- a/pyext/build.py.in
+++ b/pyext/build.py.in
@@ -35,7 +35,12 @@ cmpargs += " @CXXFLAGS@"
 
 ## Link args -- base on install-prefix, or on local lib dirs for pre-install build
 linkargs = " ".join("-L{}".format(d) for d in lookupdirs)
-linkargs += " -L@abs_top_builddir@/src/.libs" if "RIVET_LOCAL" in os.environ else "-L@prefix@/lib"
+if "RIVET_LOCAL" in os.environ:
+    linkargs += " -L@abs_top_builddir@/src/.libs"
+    if platform.system() == "Darwin":
+        linkargs += " -Wl,-rpath,@abs_top_builddir@/src/.libs"
+else:
+    linkargs += " -L@prefix@/lib"
 ## This needs to be passed separately on Mac, otherwise HepMC3 library won't be found
 if platform.system() == "Darwin": linkargs += " -Wl,-rpath,@HEPMC3LIBPATH@"
 linkargs += " @HDF5_LDFLAGS@"
