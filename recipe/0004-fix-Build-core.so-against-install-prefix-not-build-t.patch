From 6bf0ae52014de10903ef97ffb5e476ef30b400dd Mon Sep 17 00:00:00 2001
From: Chris Burr <christopher.burr@cern.ch>
Date: Tue, 3 Mar 2026 19:05:18 +0100
Subject: [PATCH] fix: Build core.so against install prefix, not build tree

Remove RIVET_LOCAL=1 from the build.py invocation so core.so links
against the install prefix ($PREFIX/lib) rather than the build tree.
This avoids the need for install_name_tool to rewrite library paths,
which fails with cctools-port's fake code signatures on macOS.

Also removes the WITH_OSX conditional and all install_name_tool calls
as they are no longer needed.
---
 pyext/Makefile.am | 26 +-------------------------
 1 file changed, 1 insertion(+), 25 deletions(-)

diff --git a/pyext/Makefile.am b/pyext/Makefile.am
index 76a776dfc..4e368f8da 100644
--- a/pyext/Makefile.am
+++ b/pyext/Makefile.am
@@ -10,39 +10,15 @@ PYCORE_SRC = \
 
 all-local: build/rivet/core.so
 
-if WITH_OSX
-
 build/rivet/core.so: build.py rivet/core.cpp $(PYCORE_SRC)
 	$(MKDIR_P) $(abs_builddir)/build/rivet
-	cd $(abs_builddir) && $(PYEXT_ENV) RIVET_LOCAL=1 $(PYTHON) $(abs_builddir)/build.py
+	cd $(abs_builddir) && $(PYEXT_ENV) $(PYTHON) $(abs_builddir)/build.py
 	touch $@
-	install_name_tool -change \
-           $(libdir)/libRivet.dylib \
-           $(abs_top_srcdir)/src/.libs/libRivet.dylib \
-           $(abs_builddir)/build/rivet/core.so
 
 # TODO: always update the .py files, without triggering an extension rebuild
 install-exec-local: build/rivet/core.so
 	$(MKDIR_P) $(DESTDIR)$(RIVET_PYTHONPATH)
 	cp -r $(abs_builddir)/build/rivet $(DESTDIR)$(RIVET_PYTHONPATH)/
-	install_name_tool -change \
-         $(abs_top_srcdir)/src/.libs/libRivet.dylib \
-         $(libdir)/libRivet.dylib \
-         $(abs_builddir)/build/rivet/core.so
-
-else
-
-build/rivet/core.so: build.py rivet/core.cpp $(PYCORE_SRC)
-	$(MKDIR_P) $(abs_builddir)/build/rivet
-	cd $(abs_builddir) && $(PYEXT_ENV) RIVET_LOCAL=1 $(PYTHON) $(abs_builddir)/build.py
-	touch $@
-
-# TODO: always update the .py files, without triggering an extension rebuild
-install-exec-local: build/rivet/core.so
-	$(MKDIR_P) $(DESTDIR)$(RIVET_PYTHONPATH)
-	cp -r $(abs_builddir)/build/rivet $(DESTDIR)$(RIVET_PYTHONPATH)/
-
-endif
 
 uninstall-local:
 	rm -rf $(DESTDIR)$(RIVET_PYTHONPATH)/rivet
