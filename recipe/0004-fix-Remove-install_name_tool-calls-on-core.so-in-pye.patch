From a8c0fa96ac843550799e54ddfdc961a1abe8b747 Mon Sep 17 00:00:00 2001
From: Chris Burr <christopher.burr@cern.ch>
Date: Tue, 3 Mar 2026 16:43:56 +0100
Subject: [PATCH] fix: Remove install_name_tool calls on core.so in pyext
 Makefile

The cctools-port install_name_tool generates a fake code signature
that is rejected by newer macOS kernels, causing 'initialization of
core did not return an extension module' at import time. The build-
time call is unnecessary because DYLD_LIBRARY_PATH is set for tests.
The install-time call is also unnecessary because the linker already
embeds the correct install_name from libRivet.dylib.
---
 pyext/Makefile.am | 8 --------
 1 file changed, 8 deletions(-)

diff --git a/pyext/Makefile.am b/pyext/Makefile.am
index 76a776dfc..c22885344 100644
--- a/pyext/Makefile.am
+++ b/pyext/Makefile.am
@@ -16,19 +16,11 @@ build/rivet/core.so: build.py rivet/core.cpp $(PYCORE_SRC)
 	$(MKDIR_P) $(abs_builddir)/build/rivet
 	cd $(abs_builddir) && $(PYEXT_ENV) RIVET_LOCAL=1 $(PYTHON) $(abs_builddir)/build.py
 	touch $@
-	install_name_tool -change \
-           $(libdir)/libRivet.dylib \
-           $(abs_top_srcdir)/src/.libs/libRivet.dylib \
-           $(abs_builddir)/build/rivet/core.so
 
 # TODO: always update the .py files, without triggering an extension rebuild
 install-exec-local: build/rivet/core.so
 	$(MKDIR_P) $(DESTDIR)$(RIVET_PYTHONPATH)
 	cp -r $(abs_builddir)/build/rivet $(DESTDIR)$(RIVET_PYTHONPATH)/
-	install_name_tool -change \
-         $(abs_top_srcdir)/src/.libs/libRivet.dylib \
-         $(libdir)/libRivet.dylib \
-         $(abs_builddir)/build/rivet/core.so
 
 else
 
