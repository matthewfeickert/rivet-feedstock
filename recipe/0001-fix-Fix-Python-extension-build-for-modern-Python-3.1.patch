From 6cd45907bc7228b0145057f0597adc833c6a74c1 Mon Sep 17 00:00:00 2001
From: Chris Burr <christopher.burr@cern.ch>
Date: Tue, 3 Mar 2026 11:31:01 +0100
Subject: [PATCH 1/5] fix: Fix Python extension build for modern Python (3.13+)

- Make libpython linkage optional since modern Python does not require
  extension modules to link against libpython. On macOS, pass
  -undefined dynamic_lookup to defer symbol resolution to runtime.
- Use sysconfig.get_path('include') instead of
  sysconfig.get_config_var('INCLUDEPY') to find Python headers, as the
  latter returns the stale build-time path which may not match the
  actual install prefix.
---
 pyext/build.py.in | 12 +++++++-----
 1 file changed, 7 insertions(+), 5 deletions(-)

diff --git a/pyext/build.py.in b/pyext/build.py.in
index a15b706a6..83e42a7b0 100644
--- a/pyext/build.py.in
+++ b/pyext/build.py.in
@@ -27,7 +27,7 @@ incargs = " ".join("-I{}".format(d) for d in incdirs)
 incargs += " -I@prefix@/include"
 incargs += " @HEPMC3CPPFLAGS@ @FASTJETCPPFLAGS@ @YODACPPFLAGS@ @HDF5_CPPFLAGS@ @HIGHFIVECPPFLAGS@"
 incargs += " @CPPFLAGS@"
-incargs += " -I" + sysconfig.get_config_var("INCLUDEPY")
+incargs += " -I" + sysconfig.get_path("include")
 
 ## Compile args
 cmpargs = "@PYEXT_CXXFLAGS@"
@@ -60,7 +60,7 @@ libargs += " @HDF5_LIBS@"
 # print("\n")
 
 ## Python compile/link args
-pyargs = "-I" + sysconfig.get_config_var("INCLUDEPY")
+pyargs = "-I" + sysconfig.get_path("include")
 libpys = [os.path.join(sysconfig.get_config_var(ld), sysconfig.get_config_var("LDLIBRARY")) for ld in ["LIBPL", "LIBDIR"]]
 libpys.extend( glob(os.path.join(sysconfig.get_config_var("LIBPL"), "libpython*.*")) )
 libpys.extend( glob(os.path.join(sysconfig.get_config_var("LIBDIR"), "libpython*.*")) )
@@ -70,10 +70,12 @@ for lp in libpys:
         libpy = lp
         break
 if libpy is None:
-    print("No libpython found in expected location exiting")
+    print("No libpython found in expected locations, continuing without explicit libpython linkage")
     print("Considered locations were:", libpys)
-    sys.exit(1)
-pyargs += " " + libpy
+    if platform.system() == "Darwin":
+        pyargs += " -undefined dynamic_lookup"
+else:
+    pyargs += " " + libpy
 pyargs += " " + sysconfig.get_config_var("LIBS")
 pyargs += " " + sysconfig.get_config_var("LIBM")
 #pyargs += " " + sysconfig.get_config_var("LINKFORSHARED")
